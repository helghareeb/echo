# Use a hoisted (flat) node_modules layout instead of pnpm's default symlinked one.
# electron-builder collects production dependencies for the packaged app.asar by
# tracing node_modules; with pnpm's isolated layout it can miss transitive deps of
# main-process packages (e.g. fluent-ffmpeg -> which/isexe/async), which shipped a
# broken build that crashed on launch with "Cannot find module 'which'". Hoisting
# makes that tracing reliable.
node-linker=hoisted
